@{
    ViewData["Title"] = "Вихід із системи";
}

<div class="auth-panel rounded-5 p-4 p-lg-5">
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-7">
            <div class="h-100">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge rounded-pill text-bg-light">Приватна особа</span>
                    <span class="badge rounded-pill text-bg-light">Притулок</span>
                    <span class="badge rounded-pill text-bg-warning">Завершення сесії</span>
                </div>
                <h1 class="display-6 fw-semibold mb-3">Вихід із PetSearchHome</h1>
                <p class="mb-4">Підтвердіть вихід, щоб завершити поточну сесію та очистити cookie авторизації. Повернутися можна в будь-який момент через форму входу.</p>
                <div class="surface-card section-card">
                    <h2 class="h5 mb-2">Що станеться після виходу</h2>
                    <p class="mb-0">Активну сесію буде закрито, доступ до приватних дій зникне до повторної авторизації.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="surface-card section-card h-100 d-flex flex-column justify-content-between">
                <div>
                    <p class="text-uppercase small text-secondary mb-1">Use-case</p>
                    <h2 class="h4 mb-3">Вихід із системи</h2>
                    <p class="mb-4">Закрийте сесію безпечно або поверніться до перегляду в режимі гостя.</p>
                </div>
                <form asp-action="Logout" method="post" class="d-grid gap-2" data-confirm="Підтвердити вихід із системи?">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Вийти</button>
                    <a asp-action="Login" class="btn btn-outline-light">Увійти знову</a>
                    <a asp-action="GuestEntry" class="btn btn-link">Перегляд як гість</a>
                </form>
            </div>
        </div>
    </div>
</div>
