@model PetSearchHome_WEB.Models.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="form-shell py-5">
    <div class="form-shell__header">
        <h1 class="h3 mb-2">@ViewData["Title"]</h1>
        <p class="text-muted">Надішлемо посилання для відновлення на вказану електронну адресу.</p>
    </div>

    <form asp-action="ForgotPassword" method="post" class="card shadow-sm surface-card">
        @Html.AntiForgeryToken()
        <div class="card-body vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div>
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary">Створити посилання</button>
            <a asp-action="Login" class="btn btn-link">Назад до входу</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
