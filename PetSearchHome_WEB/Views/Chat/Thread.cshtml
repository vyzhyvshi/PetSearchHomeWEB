@model PetSearchHome_WEB.Models.Chat.ChatThreadViewModel
@{
    ViewData["Title"] = "Р§Р°С‚";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold mb-0">Р§Р°С‚ С–Р· @Model.OtherDisplayName</h2>
            <a class="text-decoration-none" asp-controller="Profile" asp-action="Details" asp-route-id="@Model.OtherUserId">РџРµСЂРµРіР»СЏРЅСѓС‚Рё РїСЂРѕС„С–Р»СЊ</a>
        </div>
        <div class="d-flex gap-2">
            @if (Model.IsBlockedByMe)
            {
                <form asp-action="Unblock" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-warning">Р РѕР·Р±Р»РѕРєСѓРІР°С‚Рё</button>
                </form>
            }
            else
            {
                <form asp-action="Block" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-danger">Р—Р°Р±Р»РѕРєСѓРІР°С‚Рё</button>
                </form>
            }
            <form asp-action="ClearHistory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ConversationId" />
                <button type="submit" class="btn btn-outline-secondary">Очистити історію</button>
            </form>
            <a class="btn btn-outline-secondary" asp-action="Index">Р”Рѕ СЃРїРёСЃРєСѓ С‡Р°С‚С–РІ</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body" style="max-height: 520px; overflow-y: auto;">
            @if (!Model.Messages.Any())
            {
                <div class="text-muted">РќР°РїРёС€С–С‚СЊ РїРµСЂС€Рµ РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ.</div>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var message in Model.Messages)
                    {
                        <div class="d-flex @(message.IsMine ? "justify-content-end" : "justify-content-start")">
                            <div class="border rounded p-2 @(message.IsMine ? "bg-primary text-white" : "bg-light")" style="max-width: 70%;">

                                <div id="view-mode-@message.MessageId">
                                    @if (!string.IsNullOrWhiteSpace(message.Content))
                                    {
                                        <div>@message.Content</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(message.ImageUrl))
                                    {
                                        <div class="mt-2">
                                            <img src="@message.ImageUrl" alt="Р¤РѕС‚Рѕ" class="img-fluid rounded" />
                                        </div>
                                    }
                                </div>

                                @if (message.IsMine)
                                {
                                    <form id="edit-form-@message.MessageId" action="@Url.Action("Edit", "Chat", new { id = Model.ConversationId, messageId = message.MessageId })" method="post" style="display: none;" class="mt-1">
                                        @Html.AntiForgeryToken()
                                        <textarea name="newMessage" class="form-control form-control-sm mb-1 text-dark" rows="2" required>@message.Content</textarea>
                                        <div class="d-flex justify-content-end gap-3 align-items-center">
                                            <button type="button" class="btn btn-link btn-sm p-0 text-white-50 text-decoration-none" onclick="toggleEdit('@message.MessageId')">РЎРєР°СЃСѓРІР°С‚Рё</button>
                                            <button type="submit" class="btn btn-light btn-sm px-2 py-0 text-primary fw-bold">Р—Р±РµСЂРµРіС‚Рё</button>
                                        </div>
                                    </form>
                                }

                                <div class="d-flex justify-content-between align-items-center gap-3 mt-1 small @(message.IsMine ? "text-white-50" : "text-muted")">
                                    <span>@message.SentAt.ToLocalTime().ToString("g")</span>

                                    @if (message.CanDelete)
                                    {
                                        <div class="d-flex gap-2">
                                            <a href="javascript:void(0)" onclick="toggleEdit('@message.MessageId')" class="btn btn-link btn-sm p-0 text-decoration-none @(message.IsMine ? "text-white-50" : "text-muted")" title="Р РµРґР°РіСѓРІР°С‚Рё С‚РµРєСЃС‚">
                                                Р РµРґР°РіСѓРІР°С‚Рё
                                            </a>

                                            <form asp-action="DeleteMessage" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@Model.ConversationId" />
                                                <input type="hidden" name="messageId" value="@message.MessageId" />
                                                <button type="submit" class="btn btn-link btn-sm p-0 text-decoration-none @(message.IsMine ? "text-white-50" : "text-muted")">Р’РёРґР°Р»РёС‚Рё</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.IsBlockedByOther)
    {
        <div class="alert alert-warning">Р’Рё РЅРµ РјРѕР¶РµС‚Рµ РїРёСЃР°С‚Рё С†СЊРѕРјСѓ РєРѕСЂРёСЃС‚СѓРІР°С‡Сѓ, РѕСЃРєС–Р»СЊРєРё РІС–РЅ Р·Р°Р±Р»РѕРєСѓРІР°РІ С‡Р°С‚.</div>
    }
    else if (Model.IsBlockedByMe)
    {
        <div class="alert alert-warning">Р’Рё Р·Р°Р±Р»РѕРєСѓРІР°Р»Рё С†СЊРѕРіРѕ РєРѕСЂРёСЃС‚СѓРІР°С‡Р°. Р РѕР·Р±Р»РѕРєСѓР№С‚Рµ С‡Р°С‚, С‰РѕР± РїРёСЃР°С‚Рё РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ.</div>
    }
    else
    {
        <form asp-action="Send" asp-route-id="@Model.ConversationId" method="post" enctype="multipart/form-data" class="card shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body d-flex flex-column gap-2">
                <input type="text" name="message" value="@Model.Message" class="form-control" placeholder="РќР°РїРёС€С–С‚СЊ РїРѕРІС–РґРѕРјР»РµРЅРЅСЏ" maxlength="2000" />
                <div class="d-flex gap-2 align-items-center">
                    <input type="file" name="photo" class="form-control" accept="image/*" />
                    <button type="submit" class="btn btn-primary">РќР°РґС–СЃР»Р°С‚Рё</button>
                </div>
            </div>
        </form>
    }
</div>


@section Scripts {
    <script>
        function toggleEdit(messageId) {
            const viewMode = document.getElementById(`view-mode-${messageId}`);
            const editForm = document.getElementById(`edit-form-${messageId}`);

            if (viewMode.style.display === "none") {
                viewMode.style.display = "block";
                editForm.style.display = "none";
            } else {
                viewMode.style.display = "none";
                editForm.style.display = "block";

                const textarea = editForm.querySelector('textarea');
                textarea.focus();
                textarea.setSelectionRange(textarea.value.length, textarea.value.length);
            }
        }
    </script>
}

