@model PetSearchHome_WEB.Models.Listing.EditListingViewModel
@{
    ViewData["Title"] = "Редагувати оголошення";
}

<div class="listing-editor py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="page-header">
                <div>
                    <h1 class="h3 page-header__title">Редагування оголошення</h1>
                    <p class="text-muted mb-0">Після змін оголошення буде повторно відправлене на модерацію.</p>
                </div>
                <a class="btn btn-outline-secondary" asp-action="MyListings">Назад до списку</a>
            </div>

            <div class="card shadow-sm surface-card">
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="vstack gap-3">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div>
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="AnimalType" class="form-label"></label>
                                <input asp-for="AnimalType" class="form-control" placeholder="Собака, кіт, кролик..." />
                                <span asp-validation-for="AnimalType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 location-autocomplete" data-location-autocomplete data-autocomplete-url="/api/geocode/autocomplete?q=">
                                <label asp-for="Location" class="form-label"></label>
                                <input asp-for="Location" data-location-input autocomplete="off" class="form-control" placeholder="Київ, Оболонь" />
                                <div data-location-suggestions class="list-group location-autocomplete__suggestions"></div>
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                        </div>

                        <div>
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Стан тварини, характер, контакти, обставини..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="PhotoUrlsText" class="form-label"></label>
                            <textarea asp-for="PhotoUrlsText" class="form-control" rows="4" placeholder="https://..."></textarea>
                            <div class="form-text">Наразі підтримуються прямі URL-адреси фото, по одному посиланню на рядок.</div>
                            <span asp-validation-for="PhotoUrlsText" class="text-danger"></span>
                        </div>

                        <div class="form-check">
                            <input asp-for="IsUrgent" class="form-check-input" />
                            <label asp-for="IsUrgent" class="form-check-label"></label>
                        </div>

                        <div class="stack-actions">
                            <button type="submit" class="btn btn-primary">Зберегти зміни</button>
                            <a class="btn btn-light" asp-action="MyListings">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
