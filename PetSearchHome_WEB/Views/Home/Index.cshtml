@model PetSearchHome_WEB.Models.Listing.CatalogViewModel
@{
    ViewData["Title"] = "Каталог тварин";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
                <div>
                    <h2 class="h5 mb-1">Основні сценарії</h2>
                    <p class="text-muted mb-0">Швидкий доступ до створення, редагування, видалення оголошень, перегляду своїх оголошень та профілю.</p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary" asp-controller="Listing" asp-action="Create">Створити оголошення</a>
                    <a class="btn btn-outline-primary" asp-controller="Listing" asp-action="Index">Переглянути свої оголошення</a>
                    <a class="btn btn-outline-secondary" asp-controller="Profile" asp-action="Index">Переглянути профіль</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Пошук тварин</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Index" asp-controller="Home" method="get" class="vstack gap-3">
                        <div>
                            <label asp-for="Filter.SearchQuery" class="form-label">Ключові слова</label>
                            <input asp-for="Filter.SearchQuery" class="form-control" placeholder="порода, вік, характер..." />
                        </div>
                        <div>
                            <label asp-for="Filter.AnimalType" class="form-label">Тип тварини</label>
                            <input asp-for="Filter.AnimalType" class="form-control" placeholder="Собака, кіт..." />
                        </div>
                        <div>
                            <label asp-for="Filter.Location" class="form-label">Локація</label>
                            <input asp-for="Filter.Location" class="form-control" placeholder="Місто або область" />
                        </div>
                        <div class="form-check">
                            <input asp-for="Filter.OnlyUrgent" class="form-check-input" />
                            <label asp-for="Filter.OnlyUrgent" class="form-check-label">Тільки термінові</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Знайти</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h5 mb-1">Результати</h2>
                    <p class="text-muted mb-0">Знайдено: @Model.Results.Count</p>
                </div>
            </div>

            @if (Model.Results.Any())
            {
                <div class="row g-3">
                    @foreach (var listing in Model.Results)
                    {
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="row g-0 align-items-stretch">
                                    <div class="col-5 col-md-3">
                                        <div class="ratio ratio-4x3">
                                            @if (!string.IsNullOrWhiteSpace(listing.PhotoUrl))
                                            {
                                                <img src="@listing.PhotoUrl"
                                                     alt="Фото @listing.Title"
                                                     class="w-100 h-100 object-fit-cover rounded-start" />
                                            }
                                            else
                                            {
                                                <div class="bg-light d-flex flex-column justify-content-center align-items-center text-muted rounded-start">
                                                    <span class="small">Без фото</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-7 col-md-9">
                                        <div class="card-body d-flex justify-content-between align-items-start h-100">
                                            <div class="pe-3">
                                                <h3 class="h5 mb-1">@listing.Title</h3>
                                                <p class="text-muted mb-1">@listing.AnimalType • @listing.Location</p>
                                                <small class="text-secondary">Опубліковано: @listing.ListedAt.LocalDateTime.ToShortDateString()</small>
                                            </div>
                                            <div class="text-end">
                                                @if (listing.IsUrgent)
                                                {
                                                    <span class="badge bg-danger mb-2 d-inline-block">Терміново</span>
                                                }
                                                <div>
                                                    <a class="btn btn-outline-primary btn-sm"
                                                       asp-controller="Home"
                                                       asp-action="Details"
                                                       asp-route-id="@listing.Id">Деталі</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    Нічого не знайдено за поточними фільтрами.
                </div>
            }
        </div>
    </div>
</div>
