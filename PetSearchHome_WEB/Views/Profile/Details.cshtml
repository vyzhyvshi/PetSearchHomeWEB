@model PetSearchHome_WEB.Models.Profile.ProfileDetailsViewModel
@using PetSearchHome_WEB.Domain.ValueObjects
@{
    ViewData["Title"] = "Профіль користувача";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h1 class="h3 mb-1">@Model.DisplayName</h1>
                            <div class="text-muted">@Model.Role</div>
                        </div>
                        @if (Model.CanEdit)
                        {
                            <a class="btn btn-outline-secondary btn-sm" asp-action="Edit">Редагувати</a>
                        }
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@Model.Email</dd>

                        <dt class="col-sm-5">Рейтинг</dt>
                        <dd class="col-sm-7">@(Model.Rating?.ToString("0.0") ?? "Немає")</dd>

                        <dt class="col-sm-5">Відгуки</dt>
                        <dd class="col-sm-7">@Model.ReviewsCount</dd>

                        @if (!string.IsNullOrWhiteSpace(Model.Website))
                        {
                            <dt class="col-sm-5">Сайт</dt>
                            <dd class="col-sm-7"><a href="@Model.Website" target="_blank" rel="noopener noreferrer">@Model.Website</a></dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Address))
                        {
                            <dt class="col-sm-5">Адреса</dt>
                            <dd class="col-sm-7">@Model.Address</dd>
                        }
                    </dl>

                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <hr />
                        <p class="mb-0">@Model.Description</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Оголошення користувача</h2>
                        <span class="text-muted">@Model.Listings.Count</span>
                    </div>

                    @if (Model.Listings.Count == 0)
                    {
                        <div class="alert alert-light border mb-0">Оголошення ще не додані.</div>
                    }
                    else
                    {
                        <div class="vstack gap-3">
                            @foreach (var listing in Model.Listings)
                            {
                                var badgeClass = listing.Status switch
                                {
                                    ListingStatus.Published => "bg-success",
                                    ListingStatus.PendingModeration => "bg-warning text-dark",
                                    ListingStatus.Rejected => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <div class="border rounded p-3">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <a class="text-decoration-none fw-semibold" asp-controller="Home" asp-action="Details" asp-route-id="@listing.Id">@listing.Title</a>
                                                <span class="badge @badgeClass">@listing.Status</span>
                                            </div>
                                            <div class="text-muted">@listing.AnimalType • @listing.Location</div>
                                        </div>
                                        @if (listing.IsUrgent)
                                        {
                                            <span class="badge bg-danger">Терміново</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
