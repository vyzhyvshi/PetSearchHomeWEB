@model PetSearchHome_WEB.Models.Listing.EditListingViewModel
@{
    ViewData["Title"] = "Редагувати оголошення";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">Редагування оголошення</h1>
                    <p class="text-muted mb-0">Після змін оголошення буде повторно відправлене на модерацію.</p>
                </div>
                <a class="btn btn-outline-secondary" asp-action="MyListings">Назад до списку</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="vstack gap-3">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div>
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="AnimalType" class="form-label"></label>
                                <input asp-for="AnimalType" class="form-control" placeholder="Собака, кіт, кролик..." />
                                <span asp-validation-for="AnimalType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 position-relative">
                                <label asp-for="Location" class="form-label"></label>
                                <input asp-for="Location" id="location-input" autocomplete="off" class="form-control" placeholder="Київ, Оболонь" />
                                <div id="location-suggestions" class="list-group" style="z-index:1050; max-height:240px; overflow:auto; display:none;"></div>
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                        </div>

                        <div>
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Стан тварини, характер, контакти, обставини..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="PhotoUrlsText" class="form-label"></label>
                            <textarea asp-for="PhotoUrlsText" class="form-control" rows="4" placeholder="https://..."></textarea>
                            <div class="form-text">Поки що підтримуються прямі URL-адреси фото, по одному на рядок.</div>
                            <span asp-validation-for="PhotoUrlsText" class="text-danger"></span>
                        </div>

                        <div class="form-check">
                            <input asp-for="IsUrgent" class="form-check-input" />
                            <label asp-for="IsUrgent" class="form-check-label"></label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Зберегти зміни</button>
                            <a class="btn btn-light" asp-action="MyListings">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

@section Scripts {
<script>
const input = document.getElementById('location-input');
const suggestions = document.getElementById('location-suggestions');
let controller = null;
input.addEventListener('input', async function () {
 const q = this.value.trim();
 if (q.length <2) { suggestions.style.display = 'none'; return; }
 if (controller) controller.abort();
 controller = new AbortController();
 try {
 const res = await fetch(`/api/geocode/autocomplete?q=${encodeURIComponent(q)}`, { signal: controller.signal });
 if (!res.ok) throw new Error('Network');
 const list = await res.json();
 suggestions.innerHTML = '';
 if (!list || list.length ===0) { suggestions.style.display = 'none'; return; }
 for (const item of list) {
 const el = document.createElement('button');
 el.type = 'button';
 el.className = 'list-group-item list-group-item-action';
 el.textContent = item;
 el.addEventListener('click', () => {
 input.value = item;
 suggestions.style.display = 'none';
 });
 suggestions.appendChild(el);
 }
 const rect = input.getBoundingClientRect();
 suggestions.style.position = 'fixed';
 suggestions.style.left = rect.left + 'px';
 suggestions.style.top = rect.bottom + 'px';
 suggestions.style.width = rect.width + 'px';
 suggestions.style.display = 'block';
 } catch (e) {
 suggestions.style.display = 'none';
 }
});
document.addEventListener('click', (e) => { if (!input.contains(e.target) && !suggestions.contains(e.target)) suggestions.style.display = 'none'; });
</script>
}
