@model PetSearchHome_WEB.Models.Listing.CatalogViewModel
@{
    ViewData["Title"] = "Pet Search Home";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Find your new friend</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Index" asp-controller="Home" method="get" class="vstack gap-3">
                        <div>
                            <label asp-for="Filter.SearchQuery" class="form-label">Keywords</label>
                            <input asp-for="Filter.SearchQuery" class="form-control" placeholder="cat, small dog, ..." />
                        </div>
                        <div>
                            <label asp-for="Filter.AnimalType" class="form-label">Animal type</label>
                            <input asp-for="Filter.AnimalType" class="form-control" placeholder="Dog, Cat, ..." />
                        </div>
                        <div>
                            <label asp-for="Filter.Location" class="form-label">Location</label>
                            <input asp-for="Filter.Location" class="form-control" placeholder="City or region" />
                        </div>
                        <div class="form-check">
                            <input asp-for="Filter.OnlyUrgent" class="form-check-input" />
                            <label asp-for="Filter.OnlyUrgent" class="form-check-label">Urgent only</label>
                        </div>
                        <button type="submit" class="btn btn-primary">Search</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h5 mb-1">Search results</h2>
                    <p class="text-muted mb-0">@Model.Results.Count listing(s) found</p>
                </div>
            </div>

            @if (Model.Results.Any())
            {
                <div class="row g-3">
                    @foreach (var listing in Model.Results)
                    {
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-body d-flex justify-content-between align-items-start">
                                    <div>
                                        <h3 class="h5 mb-1">@listing.Title</h3>
                                        <p class="text-muted mb-1">@listing.AnimalType • @listing.Location</p>
                                        <small class="text-secondary">Listed @listing.ListedAt.LocalDateTime.ToShortDateString()</small>
                                    </div>
                                    @if (listing.IsUrgent)
                                    {
                                        <span class="badge bg-danger">Urgent</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No listings match your search yet. Try adjusting the filters.
                </div>
            }
        </div>
    </div>
</div>
