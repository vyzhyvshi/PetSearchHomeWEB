<style>
    .auth-theme {
        --auth-bg: #0b1f33;
        --auth-surface: #0f2c46;
        --auth-card: #0f172a;
        --auth-accent: #10b981;
        --auth-accent-2: #0ea5e9;
        --auth-border: #1f3b57;
        --auth-muted: #cbd5e1;
        --auth-glow: 0 20px 80px rgba(14, 165, 233, 0.25);
        background: radial-gradient(circle at 10% 20%, rgba(14, 165, 233, 0.12), transparent 30%),
                    radial-gradient(circle at 90% 10%, rgba(16, 185, 129, 0.12), transparent 30%),
                    radial-gradient(circle at 50% 80%, rgba(14, 165, 233, 0.08), transparent 35%),
                    linear-gradient(140deg, #0a1627, #0d2338 45%, #0a1627);
        color: #e2e8f0;
    }

    .auth-viewport {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        padding: 2rem 0;
    }

    .auth-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .auth-hero-card {
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.65));
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 18px;
        padding: 1.5rem;
        box-shadow: var(--auth-glow);
        backdrop-filter: blur(12px);
    }

    .auth-hero-card h1 {
        font-weight: 700;
        color: #e2e8f0;
    }

    .auth-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: rgba(14, 165, 233, 0.18);
        color: #e2e8f0;
        border: 1px solid rgba(14, 165, 233, 0.35);
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        font-size: 0.9rem;
    }

    .auth-chip--accent {
        background: rgba(16, 185, 129, 0.18);
        border-color: rgba(16, 185, 129, 0.35);
    }

    .auth-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
    }

    .auth-list li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0;
        border-bottom: 1px dashed rgba(148, 163, 184, 0.2);
        color: var(--auth-muted);
    }

    .auth-list li:last-child {
        border-bottom: none;
    }

    .auth-card {
        background: #0b1627;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: var(--auth-glow);
    }

    .auth-card .card-body {
        padding: 2rem;
    }

    .auth-card label {
        color: #94a3b8;
        font-weight: 600;
    }

    .auth-card .form-control {
        background: rgba(255, 255, 255, 0.02);
        border-color: rgba(148, 163, 184, 0.35);
        color: #e2e8f0;
    }

    .auth-card .form-control:focus {
        border-color: var(--auth-accent-2);
        box-shadow: 0 0 0 0.2rem rgba(14, 165, 233, 0.2);
    }

    .auth-card .form-text {
        color: #94a3b8;
    }

    .auth-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.65rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 12px;
        color: #e2e8f0;
        font-size: 0.9rem;
    }

    .auth-section-title {
        color: #e2e8f0;
        font-weight: 700;
    }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #94a3b8;
        margin: 0.75rem 0;
    }

    .auth-divider::before,
    .auth-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.4), transparent);
