@model PetSearchHome_WEB.Models.Chat.ChatThreadViewModel
@{
    ViewData["Title"] = "Чат";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold mb-0">Чат із @Model.OtherDisplayName</h2>
            <a class="text-decoration-none" asp-controller="Profile" asp-action="Details" asp-route-id="@Model.OtherUserId">Переглянути профіль</a>
        </div>
        <div class="d-flex gap-2">
            @if (Model.IsBlockedByMe)
            {
                <form asp-action="Unblock" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-warning">Розблокувати</button>
                </form>
            }
            else
            {
                <form asp-action="Block" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-danger">Заблокувати</button>
                </form>
            }
            <a class="btn btn-outline-secondary" asp-action="Index">До списку чатів</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body" style="max-height: 520px; overflow-y: auto;">
            @if (!Model.Messages.Any())
            {
                <div class="text-muted">Напишіть перше повідомлення.</div>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var message in Model.Messages)
                    {
                        <div class="d-flex @(message.IsMine ? "justify-content-end" : "justify-content-start")">
                            <div class="border rounded p-2 @(message.IsMine ? "bg-primary text-white" : "bg-light")" style="max-width: 70%;">
                                @if (!string.IsNullOrWhiteSpace(message.Content))
                                {
                                    <div>@message.Content</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(message.ImageUrl))
                                {
                                    <div class="mt-2">
                                        <img src="@message.ImageUrl" alt="Фото" class="img-fluid rounded" />
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-center gap-2 small @(message.IsMine ? "text-white-50" : "text-muted")">
                                    <span>@message.SentAt.ToLocalTime().ToString("g")</span>
                                    @if (message.CanDelete)
                                    {
                                        <form asp-action="DeleteMessage" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.ConversationId" />
                                            <input type="hidden" name="messageId" value="@message.MessageId" />
                                            <button type="submit" class="btn btn-link btn-sm p-0 text-decoration-none @(message.IsMine ? "text-white-50" : "text-muted")">Видалити</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.IsBlockedByOther)
    {
        <div class="alert alert-warning">Ви не можете писати цьому користувачу, оскільки він заблокував чат.</div>
    }
    else if (Model.IsBlockedByMe)
    {
        <div class="alert alert-warning">Ви заблокували цього користувача. Розблокуйте чат, щоб писати повідомлення.</div>
    }
    else
    {
        <form asp-action="Send" asp-route-id="@Model.ConversationId" method="post" enctype="multipart/form-data" class="card shadow-sm">
            @Html.AntiForgeryToken()
            <div class="card-body d-flex flex-column gap-2">
                <input type="text" name="message" value="@Model.Message" class="form-control" placeholder="Напишіть повідомлення" maxlength="2000" />
                <div class="d-flex gap-2 align-items-center">
                    <input type="file" name="photo" class="form-control" accept="image/*" />
                    <button type="submit" class="btn btn-primary">Надіслати</button>
                </div>
            </div>
        </form>
    }
</div>
