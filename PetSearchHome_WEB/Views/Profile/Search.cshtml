@model PetSearchHome_WEB.Models.Profile.UserSearchViewModel
@{
    ViewData["Title"] = "Пошук користувачів";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">@ViewData["Title"]</h2>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">До каталогу</a>
    </div>

    <form asp-controller="Profile" asp-action="Search" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Нікнейм або email" />
            <button type="submit" class="btn btn-primary">Пошук</button>
        </div>
    </form>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <div class="alert alert-info">Введіть нікнейм або email для пошуку користувачів.</div>
    }
    else if (!Model.Results.Any())
    {
        <div class="alert alert-warning">Користувачів з оголошеннями не знайдено.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var user in Model.Results)
            {
                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                   asp-controller="Profile"
                   asp-action="Details"
                   asp-route-id="@user.Id">
                    <div>
                        <div class="fw-bold">@user.DisplayName</div>
                        <div class="text-muted small">@user.Email</div>
                    </div>
                    <span class="badge bg-primary">Переглянути профіль</span>
                </a>
            }
        </div>
    }
</div>
