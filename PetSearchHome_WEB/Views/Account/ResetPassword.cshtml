@model PetSearchHome_WEB.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Новий пароль";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4 text-center">@ViewData["Title"]</h1>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <form asp-action="ResetPassword" method="post" class="card shadow-sm">
        @Html.AntiForgeryToken()
        <div class="card-body vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />
            <div>
                <label asp-for="NewPassword" class="form-label">Новий пароль</label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div>
                <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary">Змінити пароль</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
