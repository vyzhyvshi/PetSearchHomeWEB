@using System.Security.Claims
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetSearchHome</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.bundle.min.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    }
    <div class="app-shell">
        <header class="app-header">
            <nav class="navbar navbar-expand-lg app-navbar">
                <div class="container">
                    <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="app-brand-mark" aria-hidden="true">PS</span>
                        <span class="app-brand-text">
                            <span>PetSearchHome</span>
                            <span class="app-brand-subtitle">Пошук дому для тварин</span>
                        </span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Відкрити навігацію">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse justify-content-between" id="mainNavigation">
                        <ul class="navbar-nav app-nav align-items-lg-center me-lg-3">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Каталог</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Search">Користувачі</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Listing" asp-action="Create">Створити оголошення</a>
                            </li>
                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Listing" asp-action="MyListings">Мої оголошення</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Favorite" asp-action="Index">Улюблені</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Chat" asp-action="Index">Чати</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link nav-link--accent" asp-controller="Notification" asp-action="Index">Сповіщення</a>
                            </li>
                            @if (User?.IsInRole("Admin") == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-semibold" asp-area="" asp-controller="Admin" asp-action="Dashboard">Адмінка</a>
                                </li>
                            }
                        </ul>

                        <div class="stack-actions align-items-lg-center">
                            @if (isAuthenticated)
                            {
                                <a class="btn btn-light btn-sm" asp-area="" asp-controller="Profile" asp-action="Details" asp-route-id="@currentUserId">Профіль</a>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline" data-confirm="Вийти з облікового запису?">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Вийти</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-primary btn-sm" asp-area="" asp-controller="Account" asp-action="Login">Вхід</a>
                                <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Account" asp-action="RegisterIndividual">Реєстрація</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="app-main">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        <footer class="app-footer">
            <div class="container app-footer-inner d-flex flex-column flex-md-row justify-content-between gap-2">
                <div>&copy; 2026 - PetSearchHome</div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Політика конфіденційності</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.bundle.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
