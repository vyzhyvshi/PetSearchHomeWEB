@model PetSearchHome_WEB.Models.Auth.RegisterIndividualViewModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="form-shell py-5">
    <div class="form-shell__header">
        <h1 class="h3 mb-2">Створити акаунт</h1>
        <p class="text-muted">Почніть публікувати оголошення, зберігати улюблених тварин і спілкуватися з іншими користувачами.</p>
    </div>

    <div class="card shadow-sm surface-card">
        <div class="card-body">
            <form asp-action="RegisterIndividual" method="post" class="vstack gap-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="DisplayName" class="form-label">Ім’я та прізвище</label>
                    <input asp-for="DisplayName" class="form-control" autocomplete="name" />
                    <span asp-validation-for="DisplayName" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Зареєструватися</button>

                <div class="mt-2 rounded-4 border p-3 bg-light-subtle">
                    <p class="text-muted mb-1">Представляєте притулок для тварин?</p>
                    <a asp-controller="Account" asp-action="RegisterShelter" class="fw-semibold text-decoration-none">
                        Зареєструвати притулок
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="form-shell__footer text-center d-grid gap-2">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Повернутися до входу</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-link">Перейти як гість</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
