@model PetSearchHome_WEB.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Відновити пароль";
}

<div class="form-shell py-5">
    <div class="form-shell__header">
        <h1 class="h3 mb-2">@ViewData["Title"]</h1>
        <p class="text-muted">Встановіть новий пароль для входу до акаунта.</p>
    </div>

    <div class="card shadow-sm surface-card">
        <div class="card-body">
            <form asp-action="ResetPassword" method="post" class="vstack gap-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />

                <div>
                    <label asp-for="NewPassword" class="form-label">Новий пароль</label>
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Зберегти новий пароль</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
