@model ErrorViewModel
@{
    ViewData["Title"] = "Помилка сервера";
}

<div class="container text-center py-5">
    <h1 class="display-4 text-danger">Ой! Щось пішло не так.</h1>
    <h2 class="text-muted">Ми вже знаємо про проблему і працюємо над її вирішенням.</h2>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Повернутися на головну</a>
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="mt-5 text-muted small">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }
</div>