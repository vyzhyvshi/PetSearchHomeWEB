@model PetSearchHome_WEB.Models.Profile.DeleteAccountViewModel
@{
    ViewData["Title"] = "Видалити акаунт";
}

<div class="form-shell form-shell--wide py-4">
    <div class="form-shell__header text-start">
        <h1 class="h3 mb-2 text-danger">@ViewData["Title"]</h1>
        <p class="text-muted">Після підтвердження акаунт буде деактивовано, а сеанс завершено автоматично.</p>
    </div>
    <div class="alert alert-warning danger-zone">Ця дія незворотна для поточного сеансу.</div>
    <form asp-action="DeleteAccount" method="post" class="card shadow-sm surface-card" data-confirm="Видалити акаунт?">
        @Html.AntiForgeryToken()
        <div class="card-body vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div>
                <label asp-for="CurrentPassword" class="form-label">Поточний пароль</label>
                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Видалити акаунт</button>
                <a asp-action="MyProfile" class="btn btn-light">Скасувати</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
