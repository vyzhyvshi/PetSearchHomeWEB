@model PetSearchHome_WEB.Models.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Змінити пароль";
}

<div class="form-shell form-shell--wide py-4">
    <div class="form-shell__header text-start">
        <h1 class="h3 mb-2">@ViewData["Title"]</h1>
        <p class="text-muted">Оновіть пароль для безпечного доступу до свого акаунта.</p>
    </div>
    <form asp-action="ChangePassword" method="post" class="card shadow-sm surface-card">
        @Html.AntiForgeryToken()
        <div class="card-body vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div>
                <label asp-for="CurrentPassword" class="form-label">Поточний пароль</label>
                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
            <div>
                <label asp-for="NewPassword" class="form-label">Новий пароль</label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div>
                <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <a asp-action="MyProfile" class="btn btn-light">Скасувати</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
