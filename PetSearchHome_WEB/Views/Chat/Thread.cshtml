@model PetSearchHome_WEB.Models.Chat.ChatThreadViewModel
@{
    ViewData["Title"] = "Чат";
}

<div class="chat-layout py-4" data-chat-thread>
    <div class="page-header">
        <div>
            <h1 class="h3 page-header__title">Чат із @Model.OtherDisplayName</h1>
            <a class="text-decoration-none" asp-controller="Profile" asp-action="Details" asp-route-id="@Model.OtherUserId">Переглянути профіль</a>
        </div>
        <div class="stack-actions">
            @if (Model.IsBlockedByMe)
            {
                <form asp-action="Unblock" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-warning">Розблокувати</button>
                </form>
            }
            else
            {
                <form asp-action="Block" method="post" data-confirm="Заблокувати цього користувача в чаті?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ConversationId" />
                    <input type="hidden" name="otherUserId" value="@Model.OtherUserId" />
                    <button type="submit" class="btn btn-outline-danger">Заблокувати</button>
                </form>
            }
            <form asp-action="ClearHistory" method="post" data-confirm="Очистити історію цього чату?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ConversationId" />
                <button type="submit" class="btn btn-outline-secondary">Очистити історію</button>
            </form>
            <a class="btn btn-outline-secondary" asp-action="Index">До списку чатів</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="card shadow-sm surface-card mb-3">
        <div class="card-body chat-thread" data-chat-messages>
            @if (!Model.Messages.Any())
            {
                <div class="empty-state">Напишіть перше повідомлення.</div>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var message in Model.Messages)
                    {
                        var bubbleClass = message.IsMine ? "chat-bubble chat-bubble--mine" : "chat-bubble";
                        var metaClass = message.IsMine ? "text-white-50" : "text-muted";

                        <div class="chat-message-row @(message.IsMine ? "chat-message-row--mine" : string.Empty)">
                            <div class="@bubbleClass">
                                <div data-message-view="@message.MessageId">
                                    @if (!string.IsNullOrWhiteSpace(message.Content))
                                    {
                                        <div>@message.Content</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(message.ImageUrl))
                                    {
                                        <div class="mt-2">
                                            <img src="@message.ImageUrl" alt="Фото" class="img-fluid rounded" />
                                        </div>
                                    }
                                </div>

                                @if (message.IsMine)
                                {
                                    <form data-message-edit="@message.MessageId"
                                          action="@Url.Action("Edit", "Chat", new { id = Model.ConversationId, messageId = message.MessageId })"
                                          method="post"
                                          class="mt-2"
                                          hidden>
                                        @Html.AntiForgeryToken()
                                        <textarea name="newMessage" class="form-control form-control-sm mb-2 text-dark" rows="2" required>@message.Content</textarea>
                                        <div class="d-flex justify-content-end gap-3 align-items-center">
                                            <button type="button" class="chat-bubble__link @metaClass" data-chat-edit-toggle="@message.MessageId">Скасувати</button>
                                            <button type="submit" class="btn btn-light btn-sm px-3">Зберегти</button>
                                        </div>
                                    </form>
                                }

                                <div class="chat-bubble__meta @metaClass">
                                    <span>@message.SentAt.ToLocalTime().ToString("g")</span>

                                    @if (message.CanDelete)
                                    {
                                        <div class="chat-bubble__actions">
                                            <button type="button" class="chat-bubble__link @metaClass" data-chat-edit-toggle="@message.MessageId">Редагувати</button>
                                            <form asp-action="DeleteMessage" method="post" data-confirm="Видалити повідомлення?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@Model.ConversationId" />
                                                <input type="hidden" name="messageId" value="@message.MessageId" />
                                                <button type="submit" class="chat-bubble__link @metaClass">Видалити</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.IsBlockedByOther)
    {
        <div class="alert alert-warning">Ви не можете писати цьому користувачу, оскільки він заблокував чат.</div>
    }
    else if (Model.IsBlockedByMe)
    {
        <div class="alert alert-warning">Ви заблокували цього користувача. Розблокуйте чат, щоб писати повідомлення.</div>
    }
    else
    {
        <form asp-action="Send" asp-route-id="@Model.ConversationId" method="post" enctype="multipart/form-data" class="card shadow-sm surface-card">
            @Html.AntiForgeryToken()
            <div class="card-body d-flex flex-column gap-3">
                <input type="text" name="message" value="@Model.Message" class="form-control" placeholder="Напишіть повідомлення" maxlength="2000" />
                <div class="row g-2 align-items-center">
                    <div class="col-md">
                        <input type="file" name="photo" class="form-control" accept="image/*" />
                    </div>
                    <div class="col-md-auto">
                        <button type="submit" class="btn btn-primary w-100">Надіслати</button>
                    </div>
                </div>
            </div>
        </form>
    }
</div>
