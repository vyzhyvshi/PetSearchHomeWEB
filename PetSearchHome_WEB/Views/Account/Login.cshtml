@model PetSearchHome_WEB.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="form-shell py-5">
    <div class="form-shell__header">
        <h1 class="h3 mb-2">Вхід</h1>
        <p class="text-muted">Увійдіть, щоб керувати оголошеннями, чатами та улюбленими тваринами.</p>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="card shadow-sm surface-card">
        <div class="card-body">
            <form asp-action="Login" method="post" class="vstack gap-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div>
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-1">
                        <label asp-for="Password" class="form-label mb-0">Пароль</label>
                        <a asp-action="ForgotPassword" class="small">Забули пароль?</a>
                    </div>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Увійти</button>
            </form>
        </div>
    </div>

    <div class="form-shell__footer text-center d-grid gap-2">
        <a asp-controller="Account" asp-action="RegisterIndividual" class="btn btn-outline-primary">Створити акаунт</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-link">Перейти як гість</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
