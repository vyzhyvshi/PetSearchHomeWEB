@model PetSearchHome_WEB.Models.Listing.CatalogViewModel
@{
    ViewData["Title"] = "Pet Search Home";
}

<div class="container py-4">
    <div class="text-center mb-4">
        <h1 class="display-5">Find a new friend</h1>
        <p class="lead">Pets looking for a home.</p>
    </div>

    <div class="row g-3">
        @foreach (var listing in Model.Results)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-1">@listing.Title</h5>
                            @if (listing.IsUrgent)
                            {
                                <span class="badge bg-danger">Urgent</span>
                            }
                        </div>
                        <p class="card-subtitle text-muted mb-2">@listing.AnimalType · @listing.Location</p>

                        <a href="/Home/Details/@listing.Id" class="btn btn-sm btn-outline-primary mt-2">Детальніше</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>