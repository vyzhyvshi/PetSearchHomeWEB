    .auth-small {
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .auth-highlight {
        color: var(--auth-accent);
        font-weight: 700;
    }

    @@media (max-width: 575.98px) {
        .auth-card .card-body {
            padding: 1.5rem;
        }
