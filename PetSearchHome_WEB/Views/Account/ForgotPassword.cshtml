@model PetSearchHome_WEB.Models.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4 text-center">@ViewData["Title"]</h1>

    <form asp-action="ForgotPassword" method="post" class="card shadow-sm">
        @Html.AntiForgeryToken()
        <div class="card-body vstack gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div>
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary">Створити посилання</button>
            <a asp-action="Login" class="btn btn-link">Назад до входу</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
