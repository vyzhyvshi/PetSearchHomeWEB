@model PetSearchHome_WEB.Models.Auth.RegisterShelterViewModel
@{
    ViewData["Title"] = "Реєстрація притулку";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4 text-center">Реєстрація притулку</h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="RegisterShelter" method="post" class="vstack gap-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div>
                    <label asp-for="ShelterName" class="form-label">Назва притулку</label>
                    <input asp-for="ShelterName" class="form-control" autocomplete="organization" />
                    <span asp-validation-for="ShelterName" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="Email" class="form-label">Робочий Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Зареєструвати притулок</button>
            </form>
        </div>
    </div>

    <div class="text-center mt-3 d-grid gap-2">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Повернутися до входу</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-link">Перейти як гість</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
